{{! ======================================================== }}
{{! [설정 페이지] : 사이드바/헤더/브레드크럼 공통 레이아웃. 설정 컨텐츠는 main 영역에 추가 }}
{{! ======================================================== }}
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0"
    />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <title>설정 | 인트라넷</title>
    <link rel="stylesheet" href="/css/output.css" />
  </head>
  <body
    x-data="{ page: 'settings', 'loaded': true, 'darkMode': false, 'stickyMenu': false, 'sidebarToggle': false, 'scrollTop': false }"
    x-init="
         darkMode = JSON.parse(localStorage.getItem('darkMode'));
         $watch('darkMode', value => localStorage.setItem('darkMode', JSON.stringify(value)))"
    :class="{'dark bg-gray-900': darkMode === true}"
  >
    <!-- ===== Preloader Start ===== -->
    {{>partials/preloader}}
    <!-- ===== Preloader End ===== -->

    <!-- ===== Page Wrapper Start ===== -->
    <div class="flex h-screen overflow-hidden">
      <!-- ===== Sidebar Start ===== -->
      {{>partials/sidebar}}
      <!-- ===== Sidebar End ===== -->

      <!-- ===== Content Area Start ===== -->
      <div class="relative flex flex-col flex-1 overflow-x-hidden overflow-y-auto">
        {{>partials/overlay}}
        {{>partials/header}}
        <main>
          <div class="p-4 mx-auto max-w-(--breakpoint-2xl) md:p-6">
            <div x-data="{ pageName: `Settings`}">
              {{>partials/breadcrumb}}
            </div>
            <div class="rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03] lg:p-6">
              <h3 class="mb-5 text-lg font-semibold text-gray-800 dark:text-white/90 lg:mb-7">Settings</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">Settings page placeholder.</p>
            </div>
          </div>
        </main>
      </div>
    </div>
    <script type="module" src="/js/index.js"></script>
  </body>
</html>
