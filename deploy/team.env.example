# /opt/team/team.env 로 복사해 값 채운 뒤 권한 잠그기:
#   cp team.env.example /opt/team/team.env && chmod 600 /opt/team/team.env
#
# ★ 필수: Wallet(=TNS_ADMIN) 절대경로. 이게 없으면 DB 연결 실패.
TNS_ADMIN_DIR=/opt/team/wallet

# 선택: 아래를 채우면 JAR 안의 기본값 대신 외부 값으로 주입된다.
# (비워두면 application.properties 의 기본값이 사용됨)
#DB_PASSWORD=
#GEMINI_API_KEY=
#HOLIDAY_API_KEY=
#SERVER_PORT=8080
