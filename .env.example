# Copy this file to .env and fill in real values.
# .env is git-ignored.

SPRING_PROFILES_ACTIVE=prod

# Oracle Autonomous DB
DB_TNS_NAME=intranetdb_high
DB_USERNAME=ADMIN
DB_PASSWORD=changeme

# Absolute or relative host path to the Oracle Wallet folder.
# It will be mounted read-only into the container at /app/wallet.
WALLET_PATH=./backend/src/main/resources/Wallet_IntranetDB

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=replace-with-a-long-random-base64-string-at-least-64-bytes
JWT_EXPIRATION_MS=3600000

# Comma separated origins allowed by CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
